[mysql]
host = "your-mysql-host"
port = 3306
database = "agrarius_test"
username = "agrarius"
password = ""
maxPoolSize = 4
minIdle = 1
useSsl = true
allowPublicKeyRetrieval = false

[redis]
redisHost = "your-redis-host"
redisPort = 6379
redisPassword = ""

[server]
# Optional JVM property override e.g. -Dluckperms.server=server1/server2
# TOML serverId wins over JVM fallback.
serverId = "server1"

[features]
syncQuests = true
syncTeams = false
syncChunks = false
chunkSeedOnStart = false
chunkCanonicalServerId = "agr1"
chunkForceLoadSync = true
sendFullTeamData = true
# sendDeltaPackets and conflictPolicy are removed/inert (ignored if present)

[policy]
# blacklist = listed chapters/quests/tasks stay per-player; everything else team-shared
# whitelist = only listed chapters/quests/tasks are team-shared; everything else per-player
mode = "blacklist"
soloChapterIds = ["3622ED01311E6763", "67F6F5055518AC4F"]
repeatableSoloChapterIds = []
soloQuestIds = []
soloTaskIds = []
syncSoloProgressPerPlayer = true
soloRewardsPerPlayer = true
teamRewardsDedupGlobal = true
rewardFailClosed = true
teamClaimChapterIds = ["3CEC7F7BAD54E4C6"]
teamSharedChapterIds = [
    "330C551154E3E367", "312B5D7DC7779EFE", "2742F3918C76DA81", "37CD2B0E77E895ED",
    "587F453EE1BAFB79", "13B88A5F6D9187F8", "75C4C0229F2D2798", "459D60183D34C29E",
    "5617484BFC479624", "450EB2B6DF25A9EC", "05330DA4070C75C9", "62A72817F92AC262",
    "4BF4EE11E23C71FC", "10A89CD14C4DAF63", "54A26707B4CD39CC", "74FB988DE790BE0D"
]
# Per-rank bonus force-load chunks for /ftbsync chunks setranks <player> <ranks>.
# Format: list of "rank=count" strings. Matching is case-insensitive.
# rankBonuses = ["ev=1", "premium=1", "sponzor=3", "donator=5"]
rankBonuses = []

# Optional: one-shot import of legacy per-player player data
# (per-player ZIPs containing a `quests.snbt` entry). Runs on the first
# server start after enabling; the mod writes a marker file at
# <markerDir>/ftbquestssync.migration.done.<serverId> so subsequent
# restarts become no-ops. Set runOnBoot=true to enable, or pass
# -Dftbquestssync.migration.runOnBoot=true on the JVM command line.
[migration]
runOnBoot = false
# Full key prefix up to and including the last ':' before the UUID.
# Live store key shape: stratos:data:player:blob:<uuid>
redisKeyPrefix = "stratos:data:player:blob:"
redisDb = 0
# CHANGEME (optional): parent directory for the per-server marker
# file. Override when the writable runtime state should not share a
# filesystem with the toml config (e.g. NFS vs local).
markerDir = "/opt/agrarius/config"
# Remap each export's legacy player UUID to the player's CURRENT UUID from
# usercache.json before writing. Required when the server switched auth
# (offline name-based UUID -> online/premium UUID), otherwise migrated quest
# data lands under the old UUID and the player never sees it on login.
remapUuids = true
usercachePath = "/opt/agrarius/usercache.json"
# sourceMysqlHost = "CHANGEME"
sourceMysqlPort = 3306
sourceMysqlDatabase = "CHANGEME"
sourceMysqlUsername = "CHANGEME"
# sourceMysqlPassword = ""
sourcePlayersTable = "core_players"
sourceDataTable = "core_player_data"
sourceUuidColumn = "uuid"
sourceIdColumn = "id"
sourceIdPlayerColumn = "id_player"
sourceDataColumn = "data"
sourceCreatedAtColumn = "created_at"
serverIdTag = "migrator"
maxPlayers = 0
dryRun = false
# When false (default) the migrator SKIPS a team row that already exists in
# the target DB with different content, protecting live data. Set to true
# only when you explicitly want to force-overwrite existing rows.
overwriteExisting = false
# Hard cap on a single legacy blob (Redis value or MariaDB data column).
# Raise if a real player export exceeds the cap; lower to harden against
# zip bombs / malformed sources. Default 16 MiB.
maxBlobBytes = 16777216
# Hard cap on the decompressed quests.snbt entry. Default 8 MiB.
maxSnbtBytes = 8388608
# Only run migration when Config.serverId matches this value (empty = any server).
runOnServerId = ""
