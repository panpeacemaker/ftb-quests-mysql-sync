# Web companion viewer — environment config.
# Every key has a built-in default; set only what your deployment needs.

# --- MySQL (the shared FTB Quests DB, same backend as the mod) ---
AGR_DB_HOST=127.0.0.1
AGR_DB_PORT=3306
AGR_DB_USER=agrarius
AGR_DB_PASS=
AGR_DB_NAME=agrarius_test

# --- Redis (live reset push to the mod; channel MUST match the mod's) ---
AGR_REDIS_HOST=127.0.0.1
AGR_REDIS_PORT=6379
AGR_REDIS_PASS=
AGR_REDIS_CHANNEL=ftbquests:team:updated

# --- Quest definitions: local snapshot of <server>/config/ftbquests/quests ---
AGR_QUEST_LOCAL=./quests-snapshot

# --- Security overrides (dev only; NEVER set in production) ---
# AGR_ALLOW_EMPTY_PASSWORDS=1   # allows empty AGR_DB_PASS / AGR_REDIS_PASS (dev convenience)
# AGR_COOKIE_SECURE=true        # forces Secure flag on cookies; auto-enabled when NODE_ENV=production

# --- Admin auth (external login service that authorizes the reset console) ---
WOT_LOGIN_URL=
WOT_ME_URL=
AGRARIUS_ROLES=admin
AGRARIUS_ADMINS=
